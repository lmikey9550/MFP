{
  "api_listen_addr": ":18320",
  "admin_listen_addr": ":18321",
  "data_dir": "data",
  "proxy": {
    "request_timeout_ms": 120000,
    "trust_authorization_header": false,
    "max_body_bytes": 67108864
  },
  "admin": {
    "session_cookie_name": "mfp_session",
    "session_ttl_minutes": 120,
    "accounts": [
      {
        "username": "admin",
        "role": "admin",
        "password": "change-me"
      }
    ]
  },
  "providers": [
    {
      "id": "provider-main",
      "type": "openai_compatible",
      "base_url": "http://127.0.0.1:4000/v1",
      "credential_ref": "upstream_key_1",
      "credential_env": "UPSTREAM_API_KEY",
      "headers_template": {},
      "timeout_ms": 120000,
      "enabled": true,
      "models": [
        {
          "id": "provider-model-a",
          "label": "provider-model-a"
        },
        {
          "id": "provider-model-b",
          "label": "provider-model-b"
        }
      ]
    },
    {
      "id": "example-provider",
      "type": "openai_compatible",
      "base_url": "https://provider.example.com/v1",
      "credential_ref": "example_credential",
      "credential_env": "PROVIDER_API_KEY",
      "headers_template": {},
      "timeout_ms": 120000,
      "enabled": true,
      "models": [
        {
          "id": "provider-model-c",
          "label": "Provider Model C"
        }
      ]
    }
  ],
  "virtual_models": [
    {
      "id": "smart",
      "display_name": "智能模型",
      "description": "默认高质量推理链路",
      "sticky": true,
      "sticky_scope": "agent",
      "sticky_timeout_minutes": 30,
      "failover_strategy": "sequential",
      "max_attempts": 3,
      "congestion": {
        "enabled": true,
        "window_seconds": 10,
        "threshold": 5,
        "strategy": "least_loaded",
        "cooldown_seconds": 30
      },
      "candidates": [
        {
          "provider_id": "provider-main",
          "model_id": "provider-model-a",
          "label": "provider-model-a",
          "priority": 1,
          "weight": 100,
          "max_retry": 1,
          "enabled": true
        },
        {
          "provider_id": "example-provider",
          "model_id": "provider-model-c",
          "label": "Provider Model C",
          "priority": 2,
          "weight": 80,
          "max_retry": 1,
          "enabled": true
        },
        {
          "provider_id": "provider-main",
          "model_id": "provider-model-b",
          "label": "provider-model-b",
          "priority": 3,
          "weight": 60,
          "max_retry": 1,
          "enabled": true
        }
      ]
    }
  ]
}
